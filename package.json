{
  "name": "dailybread",
  "private": true,

  "scripts": {

    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",

    "check-types": "turbo run check-types",


    "docker:dev:up": "docker compose --env-file .env -f docker/compose/compose.dev.yaml up -d",

    "docker:dev:down": "docker compose --env-file .env -f docker/compose/compose.dev.yaml down",

    "docker:dev:start": "docker compose --env-file .env -f docker/compose/compose.dev.yaml start",

    "docker:dev:stop": "docker compose --env-file .env -f docker/compose/compose.dev.yaml stop",

    "docker:dev:restart": "docker compose --env-file .env -f docker/compose/compose.dev.yaml restart",

    "docker:dev:logs": "docker compose --env-file .env -f docker/compose/compose.dev.yaml logs -f",

    "docker:dev:ps": "docker compose --env-file .env -f docker/compose/compose.dev.yaml ps",

    "docker:dev:config": "docker compose --env-file .env -f docker/compose/compose.dev.yaml config",

    "docker:dev:pull": "docker compose --env-file .env -f docker/compose/compose.dev.yaml pull",


    "docker:backend:prune": "turbo prune backend --docker",

    "docker:backend:build": "docker build -f docker/backend/Dockerfile .",


    "db:generate": "pnpm --filter @repo/db db:generate",

    "db:migrate": "pnpm --filter @repo/db db:migrate",

    "db:deploy": "pnpm --filter @repo/db db:deploy",

    "db:seed": "pnpm --filter @repo/db db:seed",

    "db:seed:admin": "pnpm --filter @repo/db db:seed:admin",

    "db:seed:geography": "pnpm --filter @repo/db db:seed:geography",

    "db:super-admin": "pnpm --filter @repo/db db:super-admin"
  },

  "packageManager": "pnpm@9.0.0",

  "engines": {
    "node": ">=22"
  },

  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.3",
    "typescript": "5.9.2"
  },

  "dependencies": {
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0"
  }
}