generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


//* ==============ADMIN INFRASTRUCTURE====================

model AdminUser {
  id                  String    @id @default(uuid())
  clerkUserId         String?   @unique
  roleId              String?
  email               String    @unique
  firstName           String
  middleName          String?
  lastName            String
  employeeId          String?   @unique
  status              AdminUserStatus @default(pending)
  isActive            Boolean    @default(false)
  invitedById         String?
  invitationSentCount Int        @default(0)
  invitationSentAt    DateTime?
  lastSeenAt          DateTime?
  deactivatedAt       DateTime?
  deactivationReason  String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  role                AdminRole?      @relation(fields: [roleId], references: [id])
  invitedBy           AdminUser?      @relation("AdminInvitedBy", fields: [invitedById], references: [id])
  invitees            AdminUser[]     @relation("AdminInvitedBy")
  scopes              AdminUserScope[]
  permissions         AdminUserPermission[] @relation("UserPermissions")
  granted             AdminUserPermission[] @relation("PermissionGrantedBy")
  auditLogs           AuditLog[]

  @@index([clerkUserId])
  @@index([roleId])
  @@index([status])           
  @@index([email])
}

model AdminRole {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  description String?
  createdAt   DateTime @default(now())

  users       AdminUser[]
  permissions AdminRolePermission[]
}

model AdminPermission {
  id          String   @id @default(uuid())
  key         String   @unique
  module      String
  description String?
  isActive    Boolean  @default(true)

  roles AdminRolePermission[]
  users AdminUserPermission[]
}

model AdminRolePermission {
  roleId        String
  permissionId  String

  role          AdminRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    AdminPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model AdminUserPermission {
  id           String   @id @default(uuid())
  adminUserId  String
  permissionId String
  grantedById  String
  grantedAt    DateTime @default(now())

  adminUser    AdminUser       @relation("UserPermissions", fields: [adminUserId], references: [id], onDelete: Cascade)
  permission   AdminPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedBy    AdminUser       @relation("PermissionGrantedBy", fields: [grantedById], references: [id])

  @@unique([adminUserId, permissionId])
  @@index([adminUserId])
  @@index([permissionId])
}

///* Geographic scope for an admin user.
/// scopeType = GLOBAL  → countryId and cityId are null
/// scopeType = COUNTRY → countryId set, cityId null
/// scopeType = CITY    → both set
///
///* Valid scope types per role (enforced at service layer):
///   super_admin     → GLOBAL only
///   identity_admin  → COUNTRY or GLOBAL (GLOBAL requires super_admin grant)
///   finance         → COUNTRY
///   vendor_ops      → COUNTRY or CITY
///   customer_care   → CITY or COUNTRY (city preferred)
///   courier_ops     → CITY only
model AdminUserScope {
  id          String         @id @default(uuid())
  adminUserId String
  scopeType   AdminScopeType
  countryId   String?
  cityId      String?

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  country   Country?  @relation(fields: [countryId], references: [id])
  city      City?     @relation(fields: [cityId], references: [id])

  @@unique([adminUserId, scopeType, countryId, cityId])
  @@index([adminUserId])
  @@index([countryId])
  @@index([cityId])
}

//* Append-only audit log across all models. Written asynchronously — never blocks a request.

model AuditLog {
  id          String   @id @default(uuid())
  adminUserId String
  action      String
  entityType  String
  entityId    String?
  changes     Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

//* Long-term audit record storage.
/* Records are moved here from AuditLog after AUDIT_HOT_DAYS (90 days) 
/// by the monthly audit-archive cron job.
/// Not shown in admin UI by default — accessible via export or direct query.
/// Deleted after AUDIT_DELETE_DAYS (730 days) by the same job.
*/
model AuditLogArchive {
  id          String   @id @default(uuid())
  adminUserId String
  action      String
  entityType  String
  entityId    String?
  changes     Json?
  metadata    Json?
  createdAt   DateTime
  archivedAt  DateTime @default(now())

  @@index([adminUserId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([archivedAt])
}


/// Predefined reasons for standard admin actions.
/// Selected by admin when taking an action — stored in AuditLog.metadata.reasonCode.
model AdminActionReason {
  id          String   @id @default(uuid())
  code        String   @unique
  label       String
  description String?
  appliesTo   String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([isActive])
}

/// Pre-computed summary metrics. Refreshed every 5 minutes by a background job.
model DashboardStat {
  key       String   @id
  value     Decimal  @db.Decimal(20, 4)
  updatedAt DateTime @updatedAt
  metadata  Json?
}


//* =========GEOGRAPHY & CONFIGURATION=============

model Country {
  id                 String    @id @default(uuid())
  name               String    @unique
  code               String    @unique
  currency           String
  currencySymbol     String?
  phoneCode          String
  timezones          String[]
  status             GeoStatus @default(ACTIVE)
  createdByAdminId   String?
  createdAt          DateTime  @default(now())

  cities             City[]
  documentTypes      DocumentTypeConfig[]
  vendors            VendorAccount[]
  vendorApplications VendorApplication[]
  vendorTypes        VendorTypeCountry[]
  adminScopes        AdminUserScope[]


  @@index([status])
}

model City {
  id               String    @id @default(uuid())
  countryId        String
  name             String
  code             String?
  timezone         String
  latitude         Float?
  longitude        Float?
  status           GeoStatus @default(ACTIVE)
  createdByAdminId String?
  boundingBoxNorth Float?
  boundingBoxSouth Float?
  boundingBoxEast  Float?
  boundingBoxWest  Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  country       Country              @relation(fields: [countryId], references: [id])
  documentTypes DocumentTypeConfig[]
  serviceAreas  ServiceArea[]
  adminScopes   AdminUserScope[]

  @@unique([countryId, name])
  @@index([countryId])
  @@index([status])
}

model ServiceArea {
  id               String    @id @default(uuid())
  cityId           String
  name             String
  boundaries       Json
  status           GeoStatus @default(ACTIVE)
  createdByAdminId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  city    City                @relation(fields: [cityId], references: [id], onDelete: Cascade)
  outlets OutletServiceArea[]

  @@unique([cityId, name])
  @@index([cityId])
  @@index([status])
}

model OutletServiceArea {
  outletId      String
  serviceAreaId String

  outlet      Outlet      @relation(fields: [outletId], references: [id], onDelete: Cascade)
  serviceArea ServiceArea @relation(fields: [serviceAreaId], references: [id], onDelete: Cascade)

  @@id([outletId, serviceAreaId])
  @@index([serviceAreaId])
}


//* =========PAYMENT CONFIGURATION==========

model PaymentMethod {
  id               String            @id @default(uuid())
  code             String            @unique  // "MPESA", "BANK_TRANSFER", "PAYPAL", "AIRTEL_MONEY"
  name             String          
  type             PaymentMethodType   // MOBILE_MONEY | BANK | DIGITAL_WALLET | CARD
  direction        PaymentDirection[]  // [INBOUND, OUTBOUND] — can it collect? can it pay out?
  logoUrl          String?
  description      String?
  createdByAdminId String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())

  countryConfigs CountryPaymentMethod[]
}

model CountryPaymentMethod {
  id                String     @id @default(uuid())
  countryId         String
  paymentMethodId   String
  direction         PaymentDirection     // INBOUND or OUTBOUND
  status            CountryPaymentMethodStatus   @default(ACTIVE)
  
  // Our own collection/disbursement account details for this method in this country
  // Stored as JSON because M-Pesa needs a paybill, bank needs account+branch, PayPal needs email
  ourAccountDetails     Json?
  
  // Verification provider config for vendor account validation
  verificationProvider  String?   // "AFRICASTALKING", "SAFARICOM_DARAJA", "MANUAL"
  verificationConfig    Json?     // provider-specific config, API keys stored in env but config here
  displayOrder          Int       @default(0)

  createdByAdminId      String?
  createdAt             DateTime  @default(now())

  paymentMethod         PaymentMethod  @relation(fields: [paymentMethodId], references: [id])
  vendorPayoutAccounts  VendorPayoutAccount[]

  @@unique([countryId, paymentMethodId, direction])
  @@index([countryId])
  @@index([paymentMethodId])
  @@index([status])
}

model VendorCommissionConfig {
  id               String   @id @default(uuid())
  countryId        String   @unique   // country-level default
  rate             Float               // 0.15 = 15%
  effectiveFrom    DateTime @default(now())
  createdByAdminId String?
  createdAt        DateTime @default(now())

  @@index([countryId])
}

//* ==========VENDORS==============

model VendorType {
  id               String           @id @default(uuid())
  name             String           @unique
  description      String?
  status           VendorTypeStatus @default(ACTIVE)
  createdByAdminId String?
  deletedAt        DateTime?
  createdAt        DateTime         @default(now())

  documentTypeConfigs DocumentTypeVendorType[]
  vendorAccounts      VendorAccount[]
  vendorApplications  VendorApplication[]
  countries           VendorTypeCountry[]

  @@index([status])
}

model VendorTypeCountry {
  id               String    @id @default(uuid())
  countryId        String
  vendorTypeId     String
  status           GeoStatus @default(ACTIVE)
  createdByAdminId String?
  createdAt        DateTime  @default(now())

  country    Country    @relation(fields: [countryId], references: [id])
  vendorType VendorType @relation(fields: [vendorTypeId], references: [id])

  @@unique([countryId, vendorTypeId])
  @@index([countryId])
  @@index([vendorTypeId])
  @@index([status])
}

model DocumentTypeConfig {
  id                String             @id @default(uuid())
  name              String
  code              String
  description       String?
  scope             DocumentScope
  isInheritable     Boolean            @default(false)
  countryId         String
  cityId            String?
  isRequired        Boolean            @default(true)
  requiresExpiry    Boolean            @default(true)
  expiryWarningDays Int                @default(30)
  instructions      String?
  sampleUrl         String?
  status            DocumentTypeStatus @default(ACTIVE)
  createdByAdminId  String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  city              City?                       @relation(fields: [cityId], references: [id], onDelete: Cascade)
  country           Country                     @relation(fields: [countryId], references: [id], onDelete: Cascade)
  vendorTypeConfigs DocumentTypeVendorType[]
  storeDocuments    OutletDocument[]
  storeInheritances OutletDocumentInheritance[]
  vendorDocuments   VendorDocument[]

  @@unique([code, countryId, cityId])
  @@index([countryId])
  @@index([cityId])
  @@index([scope, countryId, cityId])
}

model DocumentTypeVendorType {
  id             String             @id @default(uuid())
  documentTypeId String
  vendorTypeId   String
  isRequired     Boolean            @default(true)
  createdAt      DateTime           @default(now())

  documentType DocumentTypeConfig @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
  vendorType   VendorType         @relation(fields: [vendorTypeId], references: [id], onDelete: Cascade)

  @@unique([documentTypeId, vendorTypeId])
  @@index([documentTypeId])
  @@index([vendorTypeId])
}

model VendorUser {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendorAccount VendorAccount?
  applications  VendorApplication?

  @@index([clerkId])
  @@index([email])
}

model VendorAccount {
  id                    String       @id @default(uuid())
  userId                String?      @unique
  vendorTypeId          String
  otherVendorType       String?
  countryId             String
  applicationId         String       @unique
  status                VendorStatus @default(ACTIVE)
  legalBusinessName     String
  businessEmail         String       @unique
  businessPhone         String
  companyRegNumber      String?
  taxRegistrationNumber String?
  taxIdType             String?
  ownerFirstName        String
  ownerLastName         String
  ownerPhone            String?
  ownerEmail            String?
  businessAddress       String
  addressLine2          String?
  postalCode            String?
  commissionRate        Float?              // null = falls back to country default
  payoutSchedule        PayoutSchedule  @default(BIWEEKLY)
  nextPayoutDate        DateTime?
  addressVerified       Boolean      @default(false)
  suspensionReason      String?
  suspendedAt           DateTime?
  suspensionUntil       DateTime?
  deactivatedAt         DateTime?
  deletedAt             DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  country               Country               @relation(fields: [countryId], references: [id])
  user                  VendorUser?           @relation(fields: [userId], references: [id])
  vendorType            VendorType            @relation(fields: [vendorTypeId], references: [id])
  application           VendorApplication?    @relation("ApplicationToAccount", fields: [applicationId], references: [id])
  outlets               Outlet[]
  documents             VendorDocument[]
  payoutAccounts        VendorPayoutAccount[]
  vendorProfile         VendorProfile?

  @@unique([userId, countryId])
  @@unique([companyRegNumber, countryId])
  @@unique([taxRegistrationNumber, countryId])
  @@unique([businessPhone, countryId])
  @@index([userId])
  @@index([countryId])
  @@index([status])
  @@index([businessEmail])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([countryId, status])
}

model VendorProfile {
  id                  String    @id @default(uuid())
  vendorAccountId     String    @unique
  displayName         String
  tagline             String?
  description         String?
  story               String?
  logoUrl             String?
  coverImageUrl       String?
  publicEmail         String?
  publicPhone         String?
  website             String?
  socialLinks         Json?
  reservationLink     String?
  primaryCuisineId    String?
  specialties         String[]
  dietaryOptions      String[]
  foundedYear         Int?
  totalReviews        Int       @default(0)
  averageRating       Float     @default(0)
  isVerifiedBadge     Boolean   @default(false)
  isTopRated          Boolean   @default(false)
  isCommunityFavorite Boolean   @default(false)
  isPublished         Boolean   @default(false)
  isFeatured          Boolean   @default(false)
  galleryImages       String[]
  videoUrls           String[]
  publishedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  primaryCuisine Cuisine?      @relation(fields: [primaryCuisineId], references: [id])
  vendorAccount  VendorAccount @relation(fields: [vendorAccountId], references: [id], onDelete: Cascade)

  @@index([vendorAccountId])
  @@index([displayName])
  @@index([primaryCuisineId])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([averageRating])
  @@index([createdAt])
  @@index([totalReviews])
}

model VendorApplication {
  id                 String                  @id @default(uuid())
  userId             String?                 @unique
  countryId          String
  vendorTypeId       String
  otherVendorType    String?
  legalBusinessName  String
  registrationNumber String?
  taxId              String?
  businessEmail      String
  businessPhone      String?
  ownerFirstName     String
  ownerLastName      String
  ownerPhone         String?
  ownerEmail         String?
  businessAddress    String
  addressLine2       String?
  postalCode         String?
  status             VendorApplicationStatus @default(DRAFT)
  revisionCount      Int                     @default(0)
  rejectionReason    String?
  revisionNotes      String?
  submittedAt        DateTime?
  reviewedAt         DateTime?
  approvedAt         DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  vendorAccount VendorAccount? @relation("ApplicationToAccount")
  country       Country        @relation(fields: [countryId], references: [id])
  user          VendorUser?    @relation(fields: [userId], references: [id])
  vendorType    VendorType     @relation(fields: [vendorTypeId], references: [id])
  documents     VendorDocument[]

  @@unique([userId, countryId], name: "application_user_country_unique")
  @@index([status])
  @@index([countryId])
}

model VendorDocument {
  id              String         @id @default(uuid())
  applicationId   String?
  vendorId        String?
  documentTypeId  String
  documentNumber  String?
  storageKey      String
  documentName    String?
  fileSize        Int?
  mimeType        String?
  issueDate       DateTime?
  expiryDate      DateTime?
  status          DocumentStatus @default(PENDING)
  uploadedAt      DateTime       @default(now())
  reviewedAt      DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  revisionNotes   String?
  supersededBy    String?
  supersededAt    DateTime?
  version         Int            @default(1)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  application       VendorApplication?          @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  documentType      DocumentTypeConfig           @relation(fields: [documentTypeId], references: [id])
  vendor            VendorAccount?               @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  inheritedByStores OutletDocumentInheritance[]

  @@index([applicationId])
  @@index([vendorId])
  @@index([documentTypeId])
  @@index([status])
  @@index([expiryDate])
}


model VendorPayoutAccount {
  id                     String         @id @default(uuid())
  vendorId               String
  countryPaymentMethodId String        // points to CountryPaymentMethod (OUTBOUND direction)
  isDefault              Boolean        @default(false)
  isActive               Boolean        @default(true)
  
  // Account details — kept flat for query performance
  accountHolderName      String?
  bankName               String?
  branchName             String?
  bankCode               String?
  accountNumber          String?
  swiftCode              String?
  iban                   String?
  routingNumber          String?
  mobileNetwork          String?
  mobileNumber           String?
  paypalEmail            String?
  stripeAccountId        String?
  
  // Verification
  verificationStatus     PayoutVerificationStatus  @default(PENDING)
  verificationMethod     String?                   // "API" | "MANUAL"
  verificationRef        String?                   // external reference from verification API
  verificationMeta       Json?                     // full API response, for audit
  verifiedAt             DateTime?
  verifiedBy             String?                   // adminUserId if MANUAL
  failureReason          String?
  
  deletedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  vendor               VendorAccount          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  countryPaymentMethod CountryPaymentMethod   @relation(fields: [countryPaymentMethodId], references: [id])

  @@index([vendorId])
  @@index([countryPaymentMethodId])
  @@index([isActive])
  @@index([verificationStatus])
}


//* ===================OUTLETS===================

model Outlet {
  id                String     @id @default(uuid())
  vendorId          String
  cityId            String
  name              String
  slug              String?     @unique
  avatar            String?
  bio               String?
  coverBanner       String?
  images            String[]
  addressLine1      String
  addressLine2      String?
  postalCode        String?
  neighborhood      String?
  latitude          Float
  longitude         Float
  deliveryRadius    Float?
  deliveryZones     Json?
  deliveryFee       Float?
  minimumOrder      Float?
  phone             String?
  email             String?
  reviewStatus      OutletReviewStatus  @default(AUTO_APPROVED)
  isMainOutlet      Boolean             @default(false)
  ratings           Float               @default(0)
  totalReviews      Int                 @default(0)
  isFeatured        Boolean             @default(false)
  adminStatus       OutletAdminStatus   @default(ACTIVE)
  flagReasons       String[]           // populated by the flagging checks on creation
  flaggedAt         DateTime?
  reviewedAt        DateTime?

  isTemporarilyClosed    Boolean   @default(false)
  temporarilyClosedUntil DateTime?

  adminReviewedBy   String?
  adminSuspendedAt  DateTime?
  adminSuspendUntil DateTime?
  adminBannedAt     DateTime?
  vendorDisabledAt  DateTime?
  deletedAt         DateTime?
  vendorUpdatedAt   DateTime?
  createdAt         DateTime          @default(now())

  vendor            VendorAccount      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  meals             Meal[]
  mealPlans         MealPlan[]
  cuisines          OutletCuisine[]
  documents         OutletDocument[]
  operatingHours    OutletOperatingHours[]
  serviceAreas      OutletServiceArea[]
  inheritedVendorDocuments OutletDocumentInheritance[]

  @@unique([vendorId, name])
  @@index([vendorId])
  @@index([cityId])
  @@index([slug])
  @@index([adminStatus])
  @@index([latitude, longitude])
}

model OutletOperatingHours {
  id         String    @id @default(uuid())
  outletId   String
  dayOfWeek  DayOfWeek
  openTime   String
  closeTime  String
  isClosed   Boolean   @default(false)
  isActive   Boolean   @default(true)
  validFrom  DateTime?
  validUntil DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([outletId, dayOfWeek, validFrom])
  @@index([outletId])
}

model OutletDocument {
  id              String             @id @default(uuid())
  outletId        String
  documentTypeId  String
  documentNumber  String?
  storageKey      String
  documentName    String?
  fileSize        Int?
  mimeType        String?
  issueDate       DateTime?
  expiryDate      DateTime?
  status          DocumentStatus     @default(PENDING)
  submittedAt     DateTime           @default(now())
  reviewedAt      DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  revisionNotes   String?
  supersededBy    String?
  supersededAt    DateTime?
  version         Int                @default(1)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  documentType DocumentTypeConfig @relation(fields: [documentTypeId], references: [id])
  outlet       Outlet             @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([outletId, documentTypeId, supersededAt])
  @@index([outletId])
  @@index([documentTypeId])
  @@index([status])
  @@index([expiryDate])
}

model OutletDocumentInheritance {
  id               String   @id @default(uuid())
  outletId         String
  vendorDocumentId String
  documentTypeId   String
  inheritedAt      DateTime @default(now())
  isActive         Boolean  @default(true)

  documentType   DocumentTypeConfig @relation(fields: [documentTypeId], references: [id])
  outlet         Outlet             @relation(fields: [outletId], references: [id], onDelete: Cascade)
  vendorDocument VendorDocument     @relation(fields: [vendorDocumentId], references: [id], onDelete: Cascade)

  @@unique([outletId, documentTypeId])
  @@index([outletId])
  @@index([vendorDocumentId])
  @@index([documentTypeId])
}

//* ==================MEALS & MENU =============================

model Cuisine {
  id               String        @id @default(uuid())
  code             String        @unique
  name             String
  description      String?
  status           CuisineStatus @default(ACTIVE)
  createdByAdminId String?
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  meals          MealCuisine[]
  outlets        OutletCuisine[]
  primaryVendors VendorProfile[]

  @@index([status])
  @@index([deletedAt])
}

model OutletCuisine {
  outletId  String
  cuisineId String

  cuisine Cuisine @relation(fields: [cuisineId], references: [id])
  outlet  Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@id([outletId, cuisineId])
  @@index([cuisineId])
}

model Meal {
  id               String     @id @default(uuid())
  outletId         String
  name             String
  description      String?
  price            Float
  mainImage        String?
  images           String[]
  portionSize      String?
  dietaryOptions   String[]
  specialties      String[]
  adminStatus      MealStatus @default(ACTIVE)
  adminSuspendedAt DateTime?
  adminBannedAt    DateTime?
  deletedAt        DateTime?
  vendorUpdatedAt  DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  outlet           Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  cuisines         MealCuisine[]
  mealPlans        MealPlanMeal[]

  @@unique([outletId, name])
  @@index([outletId])
  @@index([adminStatus])
  @@index([deletedAt])
  @@index([createdAt])
}

model MealCuisine {
  mealId    String
  cuisineId String

  cuisine   Cuisine @relation(fields: [cuisineId], references: [id], onDelete: Cascade)
  meal      Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@id([mealId, cuisineId])
  @@index([cuisineId])
}

model MealPlan {
  id               String     @id @default(uuid())
  outletId         String
  name             String
  description      String?
  price            Float?
  images           String[]
  isPublished      Boolean    @default(false)
  isFeatured       Boolean    @default(false)
  adminStatus      MealStatus @default(ACTIVE)
  adminSuspendedAt DateTime?
  adminBannedAt    DateTime?
  deletedAt        DateTime?
  vendorUpdatedAt  DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  outlet           Outlet  @relation(fields: [outletId], references: [id], onDelete: Cascade)
  meals            MealPlanMeal[]

  @@unique([outletId, name])
  @@index([outletId])
  @@index([adminStatus])
  @@index([deletedAt])
  @@index([createdAt])
}

model MealPlanMeal {
  mealPlanId  String
  mealId      String

  meal        Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  mealPlan    MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  @@id([mealPlanId, mealId])
  @@index([mealId])
}


//* ==================CUSTOMERS====================

model ConsumerAccount {
  id               String         @id @default(uuid())
  clerkId          String         @unique
  email            String         @unique
  fullName         String?
  phone            String?
  countryId        String?
  status           ConsumerStatus @default(ACTIVE)
  suspendedAt      DateTime?
  suspensionReason String?
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  addresses ConsumerAddress[]

  @@index([clerkId])
  @@index([email])
  @@index([status])
}

model ConsumerAddress {
  id                String   @id @default(uuid())
  consumerAccountId String
  label             String?
  addressLine1      String
  addressLine2      String?
  city              String
  postalCode        String?
  countryId         String
  latitude          Float?
  longitude         Float?
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  consumer ConsumerAccount @relation(fields: [consumerAccountId], references: [id], onDelete: Cascade)

  @@index([consumerAccountId])
  @@index([consumerAccountId, isDefault])
}


